# Copy to .env and adjust. Defaults match vendor_lookup_rag.config.Settings.

# Backend selection (single option each today; used by adapters/factory.py)
# VENDOR_LOOKUP_VECTOR_BACKEND=qdrant
# VENDOR_LOOKUP_EMBEDDING_BACKEND=ollama
# VENDOR_LOOKUP_AGENT_BACKEND=pydantic_ai

OLLAMA_BASE_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=vendor_master

# Models — tags must match `ollama list` after pull (names vary by Ollama library version).
# Embedding (required for ingest + retrieval)
#   ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# Chat (Pydantic AI agent) — Gemma 4 E4B (default)
#   ollama pull gemma4:e4b
CHAT_MODEL=gemma4:e4b

# Gemma 4 26B MoE — stronger, much higher VRAM; uncomment this line and comment CHAT_MODEL above to switch
#   ollama pull gemma4:26b
# CHAT_MODEL=gemma4:26b

# Must match embedding model output size (nomic-embed-text => 768)
EMBEDDING_VECTOR_SIZE=768

# Optional: points per Qdrant upsert during vendor-ingest (default 128)
# INGEST_UPSERT_BATCH_SIZE=128

# Optional: drop Qdrant hits below this cosine score before match classification (0–1)
# RETRIEVAL_MIN_SCORE=

# Optional retrieval + agent-tool telemetry (JSON lines)
# VENDOR_LOOKUP_TELEMETRY_LOG_DIR=./logs/telemetry
# TELEMETRY_LOG_TO_STDERR=false
# TELEMETRY_LOG_TO_STDOUT=false

# Agent observability: OpenTelemetry spans for LLM + tools (default true). Set false to disable.
# VENDOR_LOOKUP_AGENT_INSTRUMENT=true

# Optional Logfire (pip install 'vendor-lookup-rag[observability]'); uses logfire.configure() + instrument_pydantic_ai
# VENDOR_LOOKUP_LOGFIRE=false
# VENDOR_LOOKUP_LOGFIRE_SERVICE_NAME=vendor-lookup-rag

# Application logs: always to stdout; optional rotating file vendor_lookup_rag.log under this directory
# Level applies to both (ERROR, WARNING, INFO, DEBUG; WARN accepted as WARNING). Default ERROR.
# VENDOR_LOOKUP_LOG_DIR=./logs/app
# VENDOR_LOOKUP_LOG_LEVEL=INFO

RETRIEVAL_TOP_K=5
SCORE_THRESHOLD_EXACT=0.92
SCORE_THRESHOLD_PARTIAL=0.55

# Optional: JSON file merging logical field → header name lists (see README).
# VENDOR_CSV_COLUMN_MAP_PATH=/path/to/vendor_column_map.json
